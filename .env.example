# ============================================
# TLS/SSL Configuration (HTTPS)
# ============================================

# Your domain name (required for HTTPS with Let's Encrypt)
# Example: DOMAIN=example.com or DOMAIN=subdomain.example.com
# For local development without HTTPS, use: DOMAIN=localhost
DOMAIN=localhost

# ============================================
# Database Configuration
# ============================================

POSTGRES_USER=user
POSTGRES_PASSWORD=password
DATABASE_URL=postgresql://user:password@postgres:5432/taca_ua # pragma: allowlist secret

# ============================================
# Object Storage Configuration
# ============================================

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ============================================
# Identity and Access Management
# ============================================

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=taca-ua

# ============================================
# Message Queue Configuration
# ============================================

RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ============================================
# Django Configuration
# ============================================

# Generate a secure key for production:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY='django-insecure-0zl8)k0xtx)o+5c_k(+nxb)76p#@3rc*cm)*)gvq6*6zyjxhg$' # pragma: allowlist secret

# ============================================
# Django Configuration
# ============================================

MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=adminadmin

# ============================================
# Dev Auth Bypass (local development only)
# ============================================
# WARNING: Never set DEV_AUTH_BYPASS_ENABLED=true in production.
# When enabled, any request carrying the header
#   X-Dev-Auth-Token: <DEV_AUTH_BYPASS_TOKEN>
# is treated as authenticated without a Keycloak JWT.

DEV_AUTH_BYPASS_ENABLED=false
DEV_AUTH_BYPASS_TOKEN=super-secret-dev-token # pragma: allowlist secret
DEV_AUTH_BYPASS_ROLES=general_admin
